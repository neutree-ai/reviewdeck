{
  "name": "reviewdeck-ui",
  "version": "0.3.1",
  "description": "Embeddable React component for reviewdeck code review UI.",
  "homepage": "https://github.com/neutree-ai/reviewdeck",
  "repository": {
    "type": "git",
    "url": "https://github.com/neutree-ai/reviewdeck.git",
    "directory": "packages/reviewdeck-ui"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "main": "dist/reviewdeck-ui.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/reviewdeck-ui.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/reviewdeck-ui.css"
  },
  "scripts": {
    "build": "vp build && tsc --emitDeclarationOnly --outDir dist",
    "test": "true"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.1"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
