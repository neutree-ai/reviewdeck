{
  "name": "reviewdeck",
  "version": "0.2.6",
  "description": "Split large PR diffs into reviewable sub-patches via indexed groups.",
  "homepage": "https://github.com/neutree-ai/reviewdeck",
  "bugs": {
    "url": "https://github.com/neutree-ai/reviewdeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/neutree-ai/reviewdeck.git",
    "directory": "packages/reviewdeck"
  },
  "bin": {
    "reviewdeck": "dist/reviewdeck.mjs"
  },
  "files": [
    "dist/",
    "skills/reviewdeck",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build:cli": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/reviewdeck.mjs --banner:js='#!/usr/bin/env node'",
    "build:web": "cp -r ../../dist/web dist/web",
    "build": "npm run build:cli && npm run build:web"
  },
  "engines": {
    "node": ">=18"
  }
}
