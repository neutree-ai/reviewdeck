{
  "name": "reviewdeck-server",
  "version": "0.3.1",
  "description": "HTTP review service with MCP support for reviewdeck.",
  "homepage": "https://github.com/neutree-ai/reviewdeck",
  "bugs": {
    "url": "https://github.com/neutree-ai/reviewdeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/neutree-ai/reviewdeck.git",
    "directory": "packages/reviewdeck-server"
  },
  "bin": {
    "reviewdeck-server": "dist/reviewdeck-server.mjs"
  },
  "files": [
    "dist/",
    "src/PROMPT.md"
  ],
  "type": "module",
  "scripts": {
    "build:server": "esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/reviewdeck-server.mjs --banner:js='#!/usr/bin/env node' --external:@modelcontextprotocol/sdk --external:postgres",
    "build:web": "cp -r ../../dist/web dist/web",
    "build": "npm run build:server && npm run build:web"
  },
  "dependencies": {
    "@hono/mcp": "^0.2.4",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.12.9",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18"
  }
}
