{
  "name": "reviewdeck",
  "version": "0.5.2",
  "description": "Split large PR diffs into reviewable sub-patches via indexed groups.",
  "homepage": "https://github.com/neutree-ai/reviewdeck",
  "bugs": {
    "url": "https://github.com/neutree-ai/reviewdeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/neutree-ai/reviewdeck.git"
  },
  "bin": {
    "reviewdeck": "dist/reviewdeck.mjs"
  },
  "files": [
    "dist/reviewdeck.mjs",
    "dist/web",
    "dist/ui",
    "skills/reviewdeck",
    "README.md"
  ],
  "type": "module",
  "exports": {
    "./ui": {
      "import": "./dist/ui/reviewdeck-ui.js"
    },
    "./ui/style.css": "./dist/ui/style.css"
  },
  "scripts": {
    "test": "vp test",
    "check": "vp check",
    "check-deps": "depcruise src --config .dependency-cruiser.cjs",
    "knip": "knip",
    "build:cli": "esbuild src/cli/main.ts --bundle --platform=node --format=esm --outfile=dist/reviewdeck.mjs --banner:js='#!/usr/bin/env node'",
    "build:web": "vp build -c src/web/vite.config.ts",
    "build:ui": "vp build -c src/web/vite.config.lib.ts",
    "build": "npm run build:cli && npm run build:web && npm run build:ui",
    "lint": "vp test && vp check && knip && depcruise src --config .dependency-cruiser.cjs",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@hono/mcp": "^0.2.5",
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@pierre/diffs": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dependency-cruiser": "^17.3.9",
    "esbuild": "^0.27.4",
    "knip": "^5.86.0",
    "tailwindcss": "^4.2.1",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.11.1"
}
